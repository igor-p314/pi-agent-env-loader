# Test .env file for env-loader

# === Basic ===
SIMPLE=value
KEY=value
ANOTHER_KEY=another_value

# === With quotes ===
DOUBLE_QUOTED="hello world"
SINGLE_QUOTED='single quoted'
QUOTED_WITH_SPACE="hello world!"
QUOTED_NUM="123"

# === Escapes ===
NEWLINE=hello\nworld
TABS=hello\tworld
ESCAPED_QUOTE="he said \"hello\""
ESCAPED_SINGLE='it\'s working'
DOUBLE_BACKSLASH=path\\to\\file

# === Multiline (via \) ===
MULTI_LINE=line1\
line2\
line3

# === Extended syntax ===
EXPORT_VAR=exported_value
DEFAULT_VAR?=default_value
APPEND_VAR+=appended_value
PREPEND_VAR-=prepended_value

# === Commands in values ===
# Note: This should be parsed as literal +=, not operator
COMMAND_IN_VALUE=a+=b
DEFAULT_IN_VALUE=c?=d
QUESTION_IN_VALUE=what?

# === Comments ===
# This is a comment
VAR_BEFORE_COMMENT=value # this is comment
# Comment after

# === Inline comments (in quotes) ===
INLINE_IN_QUOTES="value #notcomment"
WITH_HASH="test#hash"

# === Edge cases ===
EMPTY_VALUE=
ONLY_EQUALS=====equals
SPACED_KEY = spaced value 
SPACED = around = signs =

# === Numbers and booleans ===
BOOL_TRUE=true
BOOL_FALSE=false
BOOL_YES=yes
BOOL_NO=no
INT=123
FLOAT=3.14
NEGATIVE=-42

# === Secret values (should be masked) ===
MY_SECRET_KEY=supersecret
API_TOKEN=token12345
PASSWORD=testpass
_PRIVATE_KEY=secretkey

# === Variables for interpolation ===
BASE_URL=https://api.example.com
INTERPOLATED=${BASE_URL}/path
PARTIAL_INTERP=$BASE_URL/path